{
  "name": "kinoo-dark",
  "type": "dark",
  "colors": {
    "editor.background": "#1c2638",
    "editor.foreground": "#e0e0e0"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#7b8fad", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#66c384" }
    },
    {
      "scope": ["constant.numeric", "constant.language.boolean"],
      "settings": { "foreground": "#f8ba88" }
    },
    {
      "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#f68dab" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": { "foreground": "#7eb8f7" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": { "foreground": "#e8d48a" }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": { "foreground": "#e0e0e0" }
    },
    {
      "scope": ["variable.other.property", "meta.object-literal.key"],
      "settings": { "foreground": "#b09ee0" }
    },
    {
      "scope": ["constant.other", "constant.language", "variable.language"],
      "settings": { "foreground": "#f8ba88" }
    },
    {
      "scope": ["keyword.operator", "punctuation"],
      "settings": { "foreground": "#5ecfcf" }
    },
    {
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": { "foreground": "#ea8686" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#f8ba88" }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": { "foreground": "#7b8fad" }
    },
    {
      "scope": ["meta.embedded", "source.groovy.embedded", "string source"],
      "settings": { "foreground": "#e0e0e0" }
    },
    {
      "scope": ["entity.name.tag.css", "support.type.property-name.css"],
      "settings": { "foreground": "#7eb8f7" }
    },
    {
      "scope": ["support.constant.property-value.css", "constant.other.color.rgb-value.css"],
      "settings": { "foreground": "#f8ba88" }
    },
    {
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#e8d48a" }
    },
    {
      "scope": ["support.type.vendored.property-name.css"],
      "settings": { "foreground": "#6dc4b0" }
    },
    {
      "scope": ["variable.css", "variable.other.less", "variable.other.sass"],
      "settings": { "foreground": "#9c85d3" }
    },
    {
      "scope": ["entity.name.import", "entity.name.package"],
      "settings": { "foreground": "#66c384" }
    },
    {
      "scope": ["markup.heading"],
      "settings": { "foreground": "#f8ba88", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#5ecfcf" }
    },
    {
      "scope": ["meta.diff.header", "meta.separator"],
      "settings": { "foreground": "#7b8fad" }
    },
    {
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#ea8686" }
    },
    {
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#66c384" }
    }
  ]
}
