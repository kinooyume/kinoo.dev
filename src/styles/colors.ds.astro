---

<section id="colors">
  <h2>Colors</h2>
  <p>Color palette and CSS variables used throughout the website.</p>

  <DSBlock title="Background Colors">
    <div class="color-grid">
      {backgrounds.map((c) => <DSColorSwatch var={c.var} hex={c.hex} />)}
    </div>
  </DSBlock>

  <DSBlock title="Surface Colors">
    <div class="color-grid">
      {surfaces.map((c) => <DSColorSwatch var={c.var} hex={c.hex} />)}
    </div>
  </DSBlock>

  <DSBlock title="Text Colors">
    <div class="color-grid">
      {texts.map((c) => <DSColorSwatch var={c.var} hex={c.hex} />)}
    </div>
  </DSBlock>

  <DSBlock title="Color Scales">
    <DSNote>
      Each section uses a themed color palette. These override <code
        >--accent-color</code
      > and <code>--secondary-accent-color</code> at the section level.
    </DSNote>

    <div class="scales">
      {
        colorScales.map((scale) => (
          <div class="scale-col">
            <span class="scale-label">{scale.label}</span>
            {scale.shades.map((c) => (
              <div class="scale-row">
                <div
                  class="scale-chip"
                  style={`background-color: var(${c.var});`}
                />
                <code>{c.var}</code>
              </div>
            ))}
          </div>
        ))
      }
    </div>
  </DSBlock>

  <DSBlock title="Border Colors">
    <div class="color-grid">
      {borders.map((c) => <DSColorSwatch var={c.var} hex={c.hex} border={c.border} />)}
    </div>
  </DSBlock>

  <DSBlock title="Usage">
    <DSNote>
      Import variables from <code>@/styles/variables.css</code> or use CSS custom
      properties directly in your styles.
    </DSNote>
  </DSBlock>
</section>

<style lang="scss">
  @use "@/styles/breakpoints" as *;

  .color-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .scales {
    display: flex;
    gap: 12px;
    overflow-x: auto;

    @include mobile {
      gap: 8px;
    }
  }

  .scale-col {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
    flex: 1;
  }

  .scale-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--light-color);
    margin-bottom: 4px;
    white-space: nowrap;
  }

  .scale-row {
    display: flex;
    align-items: center;
    gap: 6px;

    code {
      font-size: 10px;
      color: var(--text-muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
  }

  .scale-chip {
    width: 24px;
    height: 16px;
    border-radius: 3px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    flex-shrink: 0;
  }
</style>
