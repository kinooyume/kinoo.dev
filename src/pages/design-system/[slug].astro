---
import Layout from "@/layouts/Layout.astro";
import DSLayout from "@/components/design-system/DSLayout.astro";
import Sidebar from "@/components/sidebar/Sidebar.tsx";
import { sidebarSections } from "@/components/design-system/sections/index";
import NavBar from "@/components/header/NavBar.astro";
import HeaderMenu from "@/components/header/HeaderMenu.astro";
import MobileMenu from "@/components/header/MobileMenu.astro";

import FoundationsSection from "@/components/design-system/sections/FoundationsSection.astro";
import AtomsSection from "@/components/design-system/sections/AtomsSection.astro";
import CardSection from "@/components/design-system/sections/CardSection.astro";
import DiagramSection from "@/components/design-system/sections/DiagramSection.astro";
import SliderSection from "@/components/design-system/sections/SliderSection.astro";
import SectionSection from "@/components/design-system/sections/SectionSection.astro";
import HeaderSection from "@/components/design-system/sections/HeaderSection.astro";
import NavigationSection from "@/components/design-system/sections/NavigationSection.astro";
import HeroSection from "@/components/design-system/sections/HeroSection.astro";
import FormSection from "@/components/design-system/sections/FormSection.astro";
import ContactSection from "@/components/design-system/sections/ContactSection.astro";
import ArticlesSection from "@/components/design-system/sections/ArticlesSection.astro";
import FooterSection from "@/components/design-system/sections/FooterSection.astro";
import AnimationsSection from "@/components/design-system/sections/AnimationsSection.astro";
import TemplatesSection from "@/components/design-system/sections/TemplatesSection.astro";
import ExperimentalSection from "@/components/design-system/sections/ExperimentalSection.astro";
import DSComponentsSection from "@/components/design-system/sections/DSComponentsSection.astro";

const sectionComponents: Record<string, typeof FoundationsSection> = {
  foundations: FoundationsSection,
  atoms: AtomsSection,
  cards: CardSection,
  diagram: DiagramSection,
  slider: SliderSection,
  sections: SectionSection,
  header: HeaderSection,
  navigation: NavigationSection,
  hero: HeroSection,
  forms: FormSection,
  contact: ContactSection,
  articles: ArticlesSection,
  footer: FooterSection,
  animations: AnimationsSection,
  templates: TemplatesSection,
  experimental: ExperimentalSection,
  "ds-components": DSComponentsSection,
};

export function getStaticPaths() {
  const isDev = import.meta.env.DEV;
  return sidebarSections
    .filter((s) => isDev || !s.devOnly)
    .map((s) => ({
      params: { slug: s.slug },
      props: { title: s.title },
    }));
}

const visibleSections = sidebarSections.filter((s) => import.meta.env.DEV || !s.devOnly);

const { slug } = Astro.params;
const { title } = Astro.props;
const SectionComponent = sectionComponents[slug!];
---

<Layout
  title={`${title} · Design System · kinoo.dev`}
  description={`${title} — Design System kinoo.dev`}
>
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <NavBar slot="header-nav" />
  <HeaderMenu slot="header-menu" />
  <MobileMenu slot="header-menu" />
  <Sidebar sections={visibleSections} currentSlug={slug} showColorSwitcher title="Design System" slot="mobile-sidebar" client:load transition:persist="ds-mobile-sidebar" />

  <DSLayout currentSlug={slug}>
    <SectionComponent />
  </DSLayout>
</Layout>
