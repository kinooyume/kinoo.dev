---
import Layout from "@/layouts/Layout.astro";
import DSLayout from "@/components/design-system/DSLayout.astro";
import Sidebar from "@/components/sidebar/Sidebar.tsx";
import NavCard from "@/components/shared/atoms/NavCard.astro";
import { sidebarSections, DS_BASE } from "@/components/design-system/sections/index";

const isDev = import.meta.env.DEV;
const visibleSections = sidebarSections.filter((s) => isDev || !s.devOnly);
---

<Layout
  title="Design System · kinoo.dev"
  description="Components library for kinoo.dev"
>
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <Sidebar sections={visibleSections} showColorSwitcher title="Design System" slot="mobile-sidebar" client:load transition:persist="ds-mobile-sidebar" />

  <DSLayout
    title="Design System"
    description="Domain-grouped atomic design system for kinoo.dev. Components are organized by feature domain with atomic classification as metadata."
  >
    <div class="ds-intro" slot="intro">
      <p>Everything is chromatic. <code>--accent-color</code> is set on the container and every component inherits it: <code>Button</code> primary fill and alternative glow, <code>Tag</code> tint, links, blockquote borders, code block accents. The default accent is orange; each section or article category overrides it with its own color.</p>
      <div class="ds-layer">
        <h3>Structural layer</h3>
        <p>Neutral surfaces, cards, header, footer — the chrome that doesn't change between sections.</p>
      </div>
      <div class="ds-layer">
        <h3>Chromatic layer</h3>
        <p>Accent-driven components that adapt to their context. Set <code>--accent-color</code> on a container and everything inside follows: buttons, links, tags, borders, glows.</p>
      </div>
    </div>

    <nav class="ds-nav-grid">
      {visibleSections.map((section) => (
        <NavCard
          href={`${DS_BASE}/${section.slug}`}
          title={section.title}
          subtitle={`${section.items.length} component${section.items.length > 1 ? "s" : ""}`}
        />
      ))}
    </nav>
  </DSLayout>
</Layout>

<style lang="scss">
  .ds-nav-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
    margin-top: 32px;
  }
</style>
