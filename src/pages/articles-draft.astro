---
import { getCollection } from "astro:content";
import ArticlesListPage from "@/components/articles/ArticlesListPage.astro";

const articles = import.meta.env.DEV
  ? (await getCollection("articles")).sort(
      (a, b) => b.data.date.getTime() - a.data.date.getTime(),
    )
  : [];
---

{
  import.meta.env.DEV ? (
    <ArticlesListPage
      heading="Articles"
      description="Draft articles."
      badge="drafts"
      articles={articles}
      hrefBase="/articles"
    />
  ) : (
    <meta http-equiv="refresh" content="0;url=/articles" />
  )
}
