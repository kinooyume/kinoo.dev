---
import Layout from "@/layouts/Layout.astro";
import DSLayout from "@/components/design-system/DSLayout.astro";
import Sidebar from "@/components/sidebar/Sidebar.tsx";
import { sidebarSections } from "@/components/design-system/sections/index";
import Button from "@/components/shared/atoms/Button";
import MobileMenu from "@/components/header/MobileMenu.astro";

import FoundationsSection from "@/components/design-system/sections/FoundationsSection.astro";
import AtomsSection from "@/components/design-system/sections/AtomsSection.astro";
import CardSection from "@/components/design-system/sections/CardSection.astro";
import SliderSection from "@/components/design-system/sections/SliderSection.astro";
import SectionSection from "@/components/design-system/sections/SectionSection.astro";
import HeaderSection from "@/components/design-system/sections/HeaderSection.astro";
import NavigationSection from "@/components/design-system/sections/NavigationSection.astro";
import HeroSection from "@/components/design-system/sections/HeroSection.astro";
import FormSection from "@/components/design-system/sections/FormSection.astro";
import ContactSection from "@/components/design-system/sections/ContactSection.astro";
import ArticlesSection from "@/components/design-system/sections/ArticlesSection.astro";
import FooterSection from "@/components/design-system/sections/FooterSection.astro";
import DSComponentsSection from "@/components/design-system/sections/DSComponentsSection.astro";
---

<Layout
  title="Design System · kinoo.dev"
  description="Components library for kinoo.dev"
>
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <Button slot="header-menu" href="/" variant="tertiary" size="tiny">Portfolio</Button>
  <MobileMenu slot="header-menu" />
  <Sidebar sections={sidebarSections} title="Design System" slot="mobile-sidebar" client:load />

  <DSLayout
    title="Design System"
    description="Domain-grouped atomic design system for kinoo.dev. Components are organized by feature domain with atomic classification as metadata."
  >
    <div class="ds-intro" slot="intro">
      <p>The site uses two visual layers.</p>
      <div class="ds-layer">
        <h3>Structural layer</h3>
        <p>Neutral surfaces, cards, header, footer. No accent glow, no theming. <code>Button</code> primary is the one exception — it keeps the global orange fill because it's always a primary CTA.</p>
      </div>
      <div class="ds-layer">
        <h3>Chromatic layer</h3>
        <p>Activates inside a themed section or article. <code>--accent-color</code> is set on the container, and everything inside inherits it: <code>ButtonLink</code> glow, <code>Tag</code> tint, links, blockquote borders, code block accents. Each article category maps to its own color.</p>
      </div>
    </div>
    <FoundationsSection />
    <AtomsSection />
    <CardSection />
    <SliderSection />
    <SectionSection />
    <HeaderSection />
    <NavigationSection />
    <HeroSection />
    <FormSection />
    <ContactSection />
    <ArticlesSection />
    <FooterSection />
    <DSComponentsSection />
  </DSLayout>
</Layout>
