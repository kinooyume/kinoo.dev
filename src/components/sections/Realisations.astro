---
import { getCollection, render } from "astro:content";

import Section from "@/components/shared/organisms/Section.astro";
import Card from "@/components/shared/molecules/Card/Card.astro";
import CardDescription from "@/components/shared/molecules/Card/CardDescription.astro";
import CardSplit from "@/components/shared/molecules/Card/CardSplit.astro";
import Slider from "@/components/shared/molecules/Slider/Slider.tsx";
import Spotlight from "@/components/shared/molecules/Spotlight.astro";
import H3Tagged from "@/components/shared/atoms/H3Tagged.astro";
import Link from "@/components/shared/atoms/Link.astro";
import LogoBox from "@/components/shared/atoms/LogoBox.astro";
import Tag from "@/components/shared/atoms/Tag.astro";
import TagRow from "@/components/shared/atoms/TagRow.astro";
import arrow from "@/svgs/arrow.svg?raw";
import ekeynoxIcon from "@/svgs/ekeynox.svg?raw";

const svgLogos: Record<string, string> = { ekeynox: ekeynoxIcon };

const entries = await getCollection("realisations");
const realisations = entries.sort((a, b) => a.data.order - b.data.order);
const rendered = await Promise.all(
  realisations.map(async (entry) => ({
    data: entry.data,
    Content: (await render(entry)).Content,
  }))
);
---

<Section id="realisations" subtitle="Mes" title="Réalisations">
  <div class="grid" id="realisations-grid" data-spotlight>
    {rendered.map(({ data, Content }) => (
      <Spotlight color="#66c384" class={data.grid}>
        <Card>
          <CardSplit reverse={data.reverse} vertical={data.vertical}>
            <div slot="title" class="title-wrapper">
              <div class="title-container">
                <H3Tagged title={data.title} tag={data.tag} />
                {data.links.length > 0 && (
                  <p class="links-row">
                    {data.links.map((link, i) =>
                      i === 0 ? (
                        <Link href={link.href} text={link.text} />
                      ) : (
                        <span class="dotted">
                          <Link href={link.href} text={link.text} />
                        </span>
                      )
                    )}
                  </p>
                )}
              </div>
              <LogoBox>
                {data.svgLogo ? (
                  <Fragment set:html={svgLogos[data.logo]} />
                ) : (
                  <img alt={data.title} src={data.logo} />
                )}
              </LogoBox>
            </div>
            <CardDescription slot="description">
              <Content />
              {data.tags.length > 0 && (
                <TagRow>
                  {data.tags.map((t) => (
                    <Tag title={t} />
                  ))}
                </TagRow>
              )}
            </CardDescription>
            <Slider slot="aside" client:load pictures={data.pictures}>
              <Fragment set:html={arrow} />
            </Slider>
          </CardSplit>
        </Card>
      </Spotlight>
    ))}
  </div>
</Section>

<script>
  import { spotlight } from "@/lib/dom/spotlight";
  const container = document.getElementById("realisations-grid");
  if (container) spotlight(container);
</script>

<style>
  :global(#realisations) {
    --accent-color: #66c384;
    --secondary-accent-color: #a4dfb8;
    --accent-tint: var(--green-tint);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(3, minmax(0, auto));
    grid-row-gap: clamp(18px, 0.89rem + 0.84vw, 26px);
    grid-column-gap: clamp(18px, 0.89rem + 0.84vw, 26px);
  }

  .grid > :global(.ekeynox) {
    grid-area: 1 / 1 / 2 / 3;
  }

  .grid > :global(.arteflix) {
    grid-area: 2 / 1 / 3 / 2;
  }

  .grid > :global(.sunnydash) {
    grid-area: 2 / 2 / 3 / 3;
  }

  .grid > :global(.kinoodev) {
    grid-area: 3 / 1 / 4 / 3;
  }

  .title-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .title-container {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 4px;
    align-items: flex-start;
  }

  .links-row {
    margin: 0;
  }

  .links-row .dotted::before {
    content: "·";
    padding: 0 6px;
    color: var(--accent-color);
    opacity: 0.6;
  }

  @media screen and (max-width: 900px) {
    .grid {
      display: flex;
      flex-direction: column;
    }
  }
</style>
