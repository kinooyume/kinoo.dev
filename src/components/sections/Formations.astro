---
import { getCollection, render } from "astro:content";

import Section from "@/components/shared/organisms/Section.astro";
import Card from "@/components/shared/molecules/Card/Card.astro";
import CardContent from "@/components/shared/molecules/Card/CardContent.astro";
import CardDescription from "@/components/shared/molecules/Card/CardDescription.astro";
import CardTitle from "@/components/shared/molecules/Card/CardTitle.astro";
import Spotlight from "@/components/shared/molecules/Spotlight.astro";
import LogoBox from "@/components/shared/atoms/LogoBox.astro";
import Tag from "@/components/shared/atoms/Tag.astro";
import TagRow from "@/components/shared/atoms/TagRow.astro";

const entries = await getCollection("formations");
const formations = entries.sort((a, b) => a.data.order - b.data.order);
const rendered = await Promise.all(
  formations.map(async (entry) => ({
    data: entry.data,
    Content: (await render(entry)).Content,
  }))
);
---

<Section id="formations" subtitle="Mes" title="Formations">
  <div class="grid" id="formations-grid" data-spotlight>
    {rendered.map(({ data, Content }) => (
      <Spotlight color="var(--purple)" class={data.grid}>
        <Card>
          <CardContent>
            <CardTitle
              slot="title"
              title={data.title}
              tag={data.tag}
              href={data.href}
              label={data.label}
              location={data.location}
              date={data.date}
            />
            <LogoBox slot="marge" fullsize>
              <img loading="lazy" src={data.logo} alt={data.label} />
            </LogoBox>
            <CardDescription>
              <Content />
            </CardDescription>
            {data.tags.length > 0 && (
              <TagRow>
                {data.tags.map((t) => (
                  <Tag title={t} />
                ))}
              </TagRow>
            )}
          </CardContent>
        </Card>
      </Spotlight>
    ))}
  </div>
</Section>

<script>
  import { spotlight } from "@/lib/dom/spotlight";
  const container = document.getElementById("formations-grid");
  if (container) spotlight(container);
</script>

<style>
  :global(#formations) {
    --accent-color: #9c85d3;
    --secondary-accent-color: #c9bce6;
    --accent-tint: var(--purple-tint);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, minmax(0, auto));
    grid-column-gap: clamp(18px, 0.89rem + 0.84vw, 26px);
    grid-row-gap: clamp(18px, 0.89rem + 0.84vw, 26px);
  }

  .grid > :global(.epitech) {
    grid-area: 1 / 1 / 2 / 4;
  }
  .grid > :global(.manipal) {
    grid-area: 2 / 1 / 3 / 2;
  }
  .grid > :global(.derniercri) {
    grid-area: 2 / 2 / 3 / 3;
  }
  .grid > :global(.eurotunel) {
    grid-area: 2 / 3 / 3 / 4;
  }

  @media screen and (max-width: 1200px) {
    .grid {
      display: flex;
      flex-direction: column;
    }
  }
</style>
