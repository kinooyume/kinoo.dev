---
import { getCollection } from "astro:content";

import Section from "@/components/shared/organisms/Section.astro";
import ArticleCard from "@/components/articles/ArticleCard.astro";

const articles = (await getCollection("articles"))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Section id="articles" subtitle="Mes" title="Articles">
  <div class="grid" id="articles-grid" data-spotlight>
    {
      articles.map((article) => (
        <ArticleCard
          title={article.data.title}
          subtitle={article.data.subtitle}
          date={article.data.date}
          tags={article.data.tags}
          href={`/articles/${article.id}`}
        />
      ))
    }
  </div>
</Section>

<script>
  import { spotlight } from "@/lib/dom/spotlight";

  let cleanup: (() => void) | null = null;

  document.addEventListener("astro:before-swap", () => { cleanup?.(); cleanup = null; });
  function init() {
    const container = document.getElementById("articles-grid");
    if (container) cleanup = spotlight(container);
  }
  document.addEventListener("astro:page-load", init);
  init();
</script>

<style lang="scss">
  :global(#articles) {
    --accent-color: var(--orange);
    --accent-bright: var(--orange-dark);
    --secondary-accent-color: var(--orange-light);
    --accent-tint: var(--orange-tint);
    --accent-cool-shift: var(--orange-cool-shift);
  }

  .grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
</style>
