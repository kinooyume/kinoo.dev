---
import DSBlock from "@/components/design-system/DSBlock.astro";
import DSPreview from "@/components/design-system/DSPreview.astro";
import DSCode from "@/components/design-system/DSCode.astro";
import DSPropsTable from "@/components/design-system/DSPropsTable.astro";
import DSSectionHeader from "@/components/design-system/DSSectionHeader.astro";
import ChromaticPreview from "@/components/design-system/ChromaticPreview.tsx";
import ButtonComponent from "./Button";
import github from "@/svgs/github.svg?raw";
---

<section id="button">
  <DSSectionHeader title="Button" atomic="Atom" framework="solid" />
  <p>Chromatic button — inherits <code>--accent-color</code> from its container. Renders as <code>&lt;a&gt;</code> when <code>href</code> is set, <code>&lt;button&gt;</code> otherwise.</p>

  <DSBlock title="Variants">
    <DSPreview>
      <ButtonComponent client:load variant="solid">Solid</ButtonComponent>
      <ButtonComponent client:load variant="surface">Surface</ButtonComponent>
      <ButtonComponent client:load variant="ghost">Ghost</ButtonComponent>
      <ButtonComponent client:load variant="tint">Tint</ButtonComponent>
      <ButtonComponent client:load variant="cool-shift">Cool Shift</ButtonComponent>
    </DSPreview>
    <DSCode inline>&lt;Button variant="solid | surface | ghost | tint | cool-shift"&gt;...&lt;/Button&gt;</DSCode>
  </DSBlock>

  <DSBlock title="As Link">
    <DSPreview>
      <ButtonComponent href="#button" variant="solid">Solid Link</ButtonComponent>
      <ButtonComponent href="#button" variant="surface">Surface Link</ButtonComponent>
      <ButtonComponent href="#button" variant="ghost">Ghost Link</ButtonComponent>
      <ButtonComponent href="#button" variant="tint">Tint Link</ButtonComponent>
      <ButtonComponent href="#button" variant="cool-shift">Cool Shift Link</ButtonComponent>
    </DSPreview>
    <DSCode inline>&lt;Button href="#" variant="tint"&gt;...&lt;/Button&gt;</DSCode>
  </DSBlock>

  <DSBlock title="Small">
    <DSPreview>
      <ButtonComponent client:load variant="solid" size="small">Solid</ButtonComponent>
      <ButtonComponent client:load variant="surface" size="small">Surface</ButtonComponent>
      <ButtonComponent client:load variant="ghost" size="small">Ghost</ButtonComponent>
      <ButtonComponent client:load variant="tint" size="small">Tint</ButtonComponent>
      <ButtonComponent client:load variant="cool-shift" size="small">Cool Shift</ButtonComponent>
    </DSPreview>
    <DSCode inline>&lt;Button size="small"&gt;...&lt;/Button&gt;</DSCode>
  </DSBlock>

  <DSBlock title="With Icon" subtitle="Raw SVG string rendered before text">
    <DSPreview>
      <ButtonComponent href="#button" variant="solid" icon={github}>Solid</ButtonComponent>
      <ButtonComponent href="#button" variant="tint" icon={github}>Tint</ButtonComponent>
      <ButtonComponent href="#button" variant="tint" icon={github} size="small">Small</ButtonComponent>
    </DSPreview>
    <DSCode inline>&lt;Button icon=&#123;githubSvg&#125;&gt;...&lt;/Button&gt;</DSCode>
  </DSBlock>

  <DSBlock title="States">
    <DSPreview>
      <ButtonComponent client:load variant="solid" state="loading">Envoi…</ButtonComponent>
      <ButtonComponent client:load variant="solid" state="success">Message envoyé ✓</ButtonComponent>
    </DSPreview>
    <DSCode inline>&lt;Button state="loading | success"&gt;...&lt;/Button&gt;</DSCode>
  </DSBlock>

  <DSBlock title="Chromatic" subtitle="All variants adapt to --accent-color">
    <ChromaticPreview client:load>
      <ButtonComponent client:load variant="solid">Solid</ButtonComponent>
      <ButtonComponent client:load variant="tint" icon={github}>Tint</ButtonComponent>
      <ButtonComponent client:load variant="surface">Surface</ButtonComponent>
      <ButtonComponent client:load variant="ghost">Ghost</ButtonComponent>
      <ButtonComponent client:load variant="cool-shift">Cool Shift</ButtonComponent>
    </ChromaticPreview>
  </DSBlock>

  <DSBlock title="Props">
    <DSPropsTable
      headers={["Prop", "Type", "Default", "Description"]}
      rows={[
        [{ code: "variant" }, { code: '"solid" | "surface" | "ghost" | "tint" | "cool-shift"' }, { code: '"solid"' }, "Visual style variant"],
        [{ code: "size" }, { code: '"default" | "small"' }, { code: '"default"' }, "Compact 28px variant"],
        [{ code: "state" }, { code: '"idle" | "loading" | "success"' }, { code: '"idle"' }, "Button state for form feedback"],
        [{ code: "href" }, { code: "string" }, "—", "When set, renders as <a> instead of <button>"],
        [{ code: "external" }, { code: "boolean" }, "—", "Opens in new tab with noreferrer/nofollow"],
        [{ code: "icon" }, { code: "string" }, "—", "Raw SVG string rendered before text"],
        [{ code: "...attrs" }, { code: "ComponentProps<\"button\">" }, "—", "All native button attributes (disabled, type, etc.)"],
      ]}
    />
  </DSBlock>
</section>

<script>
  function init() {
    document.getElementById("button")?.addEventListener(
      "click",
      (e) => {
        const target = e.target as HTMLElement;
        if (target.closest("[data-chromatic]")) return;
        if (target.closest("button")) {
          e.preventDefault();
          e.stopPropagation();
        }
      },
      true,
    );
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
