---
import DSBlock from "@/components/design-system/DSBlock.astro";
import DSPreview from "@/components/design-system/DSPreview.astro";
import DSCode from "@/components/design-system/DSCode.astro";
import DSPropsTable from "@/components/design-system/DSPropsTable.astro";
import DSSectionHeader from "@/components/design-system/DSSectionHeader.astro";
import ButtonComponent from "./Button";
---

<section id="button">
  <DSSectionHeader title="Button" atomic="Atom" framework="solid" />
  <p>Structural button for global actions — contact form submit, primary CTAs. The primary variant uses the global orange; it's the one intentional accent in the structural layer.</p>

  <DSBlock title="Primary">
    <DSPreview>
      <ButtonComponent client:load variant="primary">Primary Button</ButtonComponent>
      <ButtonComponent href="#button" variant="primary">Primary Link</ButtonComponent>
    </DSPreview>
    <DSCode inline>&lt;Button variant="primary"&gt;...&lt;/Button&gt;</DSCode>
  </DSBlock>

  <DSBlock title="Secondary">
    <DSPreview>
      <ButtonComponent client:load variant="secondary">Secondary Button</ButtonComponent>
      <ButtonComponent href="#button" variant="secondary">Secondary Link</ButtonComponent>
    </DSPreview>
    <DSCode inline>&lt;Button variant="secondary"&gt;...&lt;/Button&gt;</DSCode>
  </DSBlock>

  <DSBlock title="Tertiary">
    <DSPreview>
      <ButtonComponent client:load variant="tertiary">Tertiary Button</ButtonComponent>
      <ButtonComponent href="#button" variant="tertiary">Tertiary Link</ButtonComponent>
    </DSPreview>
    <DSCode inline>&lt;Button variant="tertiary"&gt;...&lt;/Button&gt;</DSCode>
  </DSBlock>

  <DSBlock title="Tiny">
    <DSPreview>
      <ButtonComponent client:load variant="primary" size="tiny">Tiny Primary</ButtonComponent>
      <ButtonComponent client:load variant="secondary" size="tiny">Tiny Secondary</ButtonComponent>
      <ButtonComponent client:load variant="tertiary" size="tiny">Design System</ButtonComponent>
      <ButtonComponent client:load variant="tertiary" size="tiny">CV</ButtonComponent>
    </DSPreview>
    <DSCode inline>&lt;Button size="tiny"&gt;...&lt;/Button&gt;</DSCode>
  </DSBlock>

  <DSBlock title="Loading State">
    <DSPreview>
      <ButtonComponent client:load variant="primary" state="loading">Envoi…</ButtonComponent>
    </DSPreview>
    <DSCode inline>&lt;Button state="loading"&gt;Envoi…&lt;/Button&gt;</DSCode>
  </DSBlock>

  <DSBlock title="Success State">
    <DSPreview>
      <ButtonComponent client:load variant="primary" state="success">Message envoyé ✓</ButtonComponent>
    </DSPreview>
    <DSCode inline>&lt;Button state="success"&gt;Message envoyé ✓&lt;/Button&gt;</DSCode>
  </DSBlock>

  <DSBlock title="Props">
    <DSPropsTable
      headers={["Prop", "Type", "Default", "Description"]}
      rows={[
        [{ code: "variant" }, { code: '"primary" | "secondary" | "tertiary"' }, { code: '"primary"' }, "Visual style variant"],
        [{ code: "size" }, { code: '"default" | "tiny"' }, { code: '"default"' }, "Compact 28px variant"],
        [{ code: "state" }, { code: '"idle" | "loading" | "success"' }, { code: '"idle"' }, "Button state for form feedback"],
        [{ code: "href" }, { code: "string" }, "—", "When set, renders as <a> instead of <button>"],
        [{ code: "external" }, { code: "boolean" }, "—", "Opens in new tab with noreferrer/nofollow"],
        [{ code: "...attrs" }, { code: "ComponentProps<\"button\">" }, "—", "All native button attributes (disabled, type, etc.)"],
      ]}
    />
  </DSBlock>
</section>

<script>
  document.getElementById("button")?.addEventListener(
    "click",
    (e) => {
      if ((e.target as HTMLElement).closest("button")) {
        e.preventDefault();
        e.stopPropagation();
      }
    },
    true,
  );
</script>
