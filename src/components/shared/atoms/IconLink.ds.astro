---
import IconLinkComponent from "./IconLink.astro";
import DSBlock from "@/components/design-system/DSBlock.astro";
import DSPreview from "@/components/design-system/DSPreview.astro";
import DSPropsTable from "@/components/design-system/DSPropsTable.astro";
import DSSectionHeader from "@/components/design-system/DSSectionHeader.astro";
import ChromaticPreview from "@/components/design-system/ChromaticPreview.tsx";
import github from "@/svgs/github.svg?raw";
import linkedin from "@/svgs/linkedin.svg?raw";
import cv from "@/svgs/cv.svg?raw";
---

<section id="iconlink">
  <DSSectionHeader title="IconLink" atomic="Atom" framework="astro" />
  <p>Icon or badge link with hover tooltip. Inherits <code>--accent-color</code> on hover.</p>

  <DSBlock title="Icon Variant">
    <DSPreview>
      <IconLinkComponent href="#iconlink" label="GitHub">
        <Fragment set:html={github} />
      </IconLinkComponent>
      <IconLinkComponent href="#iconlink" label="LinkedIn">
        <Fragment set:html={linkedin} />
      </IconLinkComponent>
      <IconLinkComponent href="#iconlink" label="CV">
        <Fragment set:html={cv} />
      </IconLinkComponent>
    </DSPreview>
  </DSBlock>

  <DSBlock title="Badge Variant">
    <DSPreview>
      <IconLinkComponent href="#iconlink" label="DS" variant="badge" />
      <IconLinkComponent href="#iconlink" label="CV" variant="badge" />
    </DSPreview>
  </DSBlock>

  <DSBlock title="Chromatic">
    <ChromaticPreview client:load>
      <IconLinkComponent href="#iconlink" label="GitHub">
        <Fragment set:html={github} />
      </IconLinkComponent>
      <IconLinkComponent href="#iconlink" label="LinkedIn">
        <Fragment set:html={linkedin} />
      </IconLinkComponent>
      <IconLinkComponent href="#iconlink" label="CV">
        <Fragment set:html={cv} />
      </IconLinkComponent>
      <IconLinkComponent href="#iconlink" label="DS" variant="badge" />
    </ChromaticPreview>
  </DSBlock>

  <DSBlock title="Props">
    <DSPropsTable
      headers={["Prop", "Type", "Default", "Description"]}
      rows={[
        [{ code: "href" }, "string", "required", "Link destination"],
        [{ code: "label" }, "string", "required", "Accessible label (and badge text)"],
        [{ code: "tooltip" }, "string", "label", "Tooltip text on hover"],
        [{ code: "variant" }, { code: '"icon" | "badge"' }, { code: '"icon"' }, "Icon with tooltip or inline badge"],
        [{ code: "external" }, "boolean", "false", "Opens in new tab"],
      ]}
    />
  </DSBlock>
</section>
