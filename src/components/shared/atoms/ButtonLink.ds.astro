---
import ButtonLinkComponent from "./ButtonLink.astro";
import github from "@/svgs/github.svg?raw";
import DSBlock from "@/components/design-system/DSBlock.astro";
import DSPreview from "@/components/design-system/DSPreview.astro";
import DSCode from "@/components/design-system/DSCode.astro";
import DSPropsTable from "@/components/design-system/DSPropsTable.astro";
import DSSectionHeader from "@/components/design-system/DSSectionHeader.astro";
---

<section id="buttonlink">
  <DSSectionHeader title="ButtonLink" atomic="Atom" framework="astro" />
  <p>Astro equivalent of <code>Button variant="alternative"</code>. Chromatic tint background, accent text, glow on hover — inherits <code>--accent-color</code>.</p>

  <DSBlock title="Default">
    <DSPreview>
      <ButtonLinkComponent href="#" text="View project" />
    </DSPreview>
    <DSCode inline>href="#" text="View project"</DSCode>
  </DSBlock>

  <DSBlock title="With Icon">
    <DSPreview>
      <ButtonLinkComponent href="#" text="Voir plus sur GitHub" icon={github} />
    </DSPreview>
    <DSCode inline>href="#" text="Voir plus sur GitHub" icon=&#123;githubSvg&#125;</DSCode>
  </DSBlock>

  <DSBlock title="Tiny">
    <DSPreview>
      <ButtonLinkComponent href="#" text="Tiny" tiny />
      <ButtonLinkComponent href="#" text="Tiny with icon" icon={github} tiny />
    </DSPreview>
    <DSCode inline>href="#" text="Tiny" tiny</DSCode>
  </DSBlock>

  <DSBlock title="Chromatic" subtitle="Adapts to --accent-color">
    <DSPreview>
      <div class="themed">
        <div style="--accent-color: var(--orange); --accent-tint: var(--orange-tint);">
          <ButtonLinkComponent href="#" text="Orange" icon={github} />
        </div>
        <div style="--accent-color: var(--green); --accent-tint: var(--green-tint);">
          <ButtonLinkComponent href="#" text="Green" icon={github} />
        </div>
        <div style="--accent-color: var(--pink); --accent-tint: var(--pink-tint);">
          <ButtonLinkComponent href="#" text="Pink" icon={github} />
        </div>
        <div style="--accent-color: var(--purple); --accent-tint: var(--purple-tint);">
          <ButtonLinkComponent href="#" text="Purple" icon={github} />
        </div>
      </div>
    </DSPreview>
  </DSBlock>

  <DSBlock title="Props">
    <DSPropsTable
      headers={["Prop", "Type", "Default", "Description"]}
      rows={[
        [{ code: "href" }, "string", "required", "Link destination"],
        [{ code: "text" }, "string", "required", "Button label"],
        [{ code: "icon" }, "string", "-", "Raw SVG string (rendered before text)"],
        [{ code: "tiny" }, "boolean", "false", "Compact variant"],
      ]}
    />
  </DSBlock>
</section>

<style lang="scss">
  .themed {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
</style>
