---
interface Props {
  text: string;
  as?: string;
  animation?: "wave" | "slide";
  trigger?: string;
  class?: string;
}

const { text, as: Tag = "span", animation = "wave", trigger, class: className } = Astro.props;

const letters =
  animation === "wave"
    ? text.replace(/\S/g, "<span class='reveal-letter'>$&</span>")
    : null;
---

<Tag class={className} data-reveal-text={animation} data-reveal-trigger={trigger}>
  {letters ? <Fragment set:html={letters} /> : text}
</Tag>

<script>
  import { animate, stagger } from "animejs";
  import { on } from "@/lib/emitter";
  import { hasPlayed, markPlayed } from "@/lib/animations/sessionTracker";

  function showImmediate(el: HTMLElement, type: string) {
    if (type === "wave") {
      el.querySelectorAll<HTMLElement>(".reveal-letter").forEach((l) => { l.style.transform = "none"; });
    } else {
      el.style.opacity = "1";
      el.style.transform = "none";
    }
  }

  function initRevealText() {
    document
      .querySelectorAll<HTMLElement>("[data-reveal-trigger]")
      .forEach((el) => {
        const trigger = el.dataset.revealTrigger;
        if (!trigger) return;
        const siblings = document.querySelectorAll(
          `[data-reveal-trigger="${trigger}"]`,
        );
        const index = Array.from(siblings).indexOf(el);
        const type = el.dataset.revealText;
        const key = `reveal-text:${trigger}:${index}`;

        if (hasPlayed(key)) {
          showImmediate(el, type ?? "wave");
          return;
        }

        if (type === "wave") {
          el.style.overflow = "hidden";
          el.querySelectorAll<HTMLElement>(".reveal-letter").forEach((l) => {
            l.style.display = "inline-block";
            l.style.transform = "translateY(1.1em)";
          });
        } else {
          el.style.opacity = "0";
          el.style.transform = "translateX(30px)";
        }

        on(trigger, () => {
          markPlayed(key);

          if (type === "wave") {
            const letters = el.querySelectorAll(".reveal-letter");
            if (!letters.length) return;
            animate(letters, {
              translateY: ["1.1em", 0],
              duration: 750,
              delay: stagger(30, { start: 200 + index * 150 }),
              ease: "outElastic(1, .5)",
            });
          } else {
            animate(el, {
              opacity: [0, 1],
              translateX: [30, 0],
              duration: 600,
              delay: 250,
              ease: "outElastic(1, .5)",
            });
          }
        });
      });
  }

  document.addEventListener("astro:page-load", initRevealText);
  initRevealText();
</script>
