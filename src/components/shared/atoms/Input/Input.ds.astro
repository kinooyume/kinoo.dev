---
import InputComponent from "./Input";
import DSBlock from "@/components/design-system/DSBlock.astro";
import DSPreview from "@/components/design-system/DSPreview.astro";
import DSCode from "@/components/design-system/DSCode.astro";
import DSPropsTable from "@/components/design-system/DSPropsTable.astro";
import DSSectionHeader from "@/components/design-system/DSSectionHeader.astro";
import ChromaticPreview from "@/components/design-system/ChromaticPreview.astro";
---

<section id="input">
  <DSSectionHeader title="Input" atomic="Atom" framework="solid" />
  <p>Chromatic text input — focus border and glow inherit <code>--accent-color</code>.</p>

  <DSBlock title="Default">
    <DSPreview>
      <InputComponent client:load placeholder="Claude Monet" type="text" />
    </DSPreview>
    <DSCode inline>&lt;Input placeholder="Claude Monet" type="text" /&gt;</DSCode>
  </DSBlock>

  <DSBlock title="Invalid">
    <DSPreview>
      <InputComponent client:load placeholder="Claude Monet" type="text" invalid />
    </DSPreview>
    <DSCode inline>&lt;Input invalid placeholder="..." /&gt;</DSCode>
  </DSBlock>

  <DSBlock title="Chromatic" subtitle="Focus adapts to --accent-color">
    <ChromaticPreview>
      <InputComponent client:load placeholder="Focus me" type="text" />
    </ChromaticPreview>
  </DSBlock>

  <DSBlock title="Props">
    <DSPropsTable
      headers={["Prop", "Type", "Default", "Description"]}
      rows={[
        [{ code: "invalid" }, { code: "boolean" }, { code: "false" }, "Toggles red border/background"],
        [{ code: "...attrs" }, { code: 'ComponentProps<"input">' }, "—", "All native input attributes"],
      ]}
    />
  </DSBlock>
</section>
