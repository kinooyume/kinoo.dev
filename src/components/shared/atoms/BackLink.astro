---
import Link from "./Link.astro";
import arrowLeft from "@/svgs/arrow-left.svg?raw";

type Props = {
  href: string;
  text: string;
};

const { href, text } = Astro.props;
---

<Link href={href} text={text} class="back-link">
  <span class="back-arrow" slot="prepend" set:html={arrowLeft} />
</Link>

<style lang="scss">
  .back-arrow :global(svg) {
    width: 14px;
    height: 14px;
  }
</style>
