---
import externalLinkIcon from "@/svgs/external-link.svg?raw";

interface Props {
  href: string;
  text: string;
  icon?: string;
}

const { href, text, icon } = Astro.props;
const isExternal = href.startsWith("http");
const externalProps = isExternal
  ? { target: "_blank", rel: "noreferrer nofollow noopener" }
  : {};
const displayIcon = icon ?? (isExternal ? externalLinkIcon : undefined);
---

<a class="badge-link" href={href} {...externalProps}>
  {text}
  {displayIcon && <span class="icon" aria-hidden="true" set:html={displayIcon} />}
</a>

<style lang="scss">
  @use "@/styles/ghost" as *;

  a {
    @include ghost;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    height: 22px;
    padding: 0 8px;
    font-size: var(--font-size-3xs);
    border-radius: var(--radius-sm);
    text-decoration: none;
    cursor: pointer;
  }

  .icon :global(svg) {
    display: block;
    width: 11px;
    height: 11px;
    stroke: currentColor;
  }

  @media (hover: hover) {
    a:hover {
      transform: translateY(-2px);
    }

    a:active {
      transform: translateY(2px);
      transition: var(--transition-snap);
    }
  }
</style>
