---
interface Props {
  title: string;
  icon?: string;
  animated?: boolean;
  highlight?: boolean;
  outline?: boolean;
}

const { animated, title, icon, highlight, outline } = Astro.props;
---

<div class=`tag ${animated ? "tag-animated" : "show"} ${highlight ? "highlight" : ""} ${outline ? "outline" : ""}`>
  {icon && <Fragment set:html={icon} />}
  <span>{title}</span>
</div>

<style lang="scss" is:global>
  .tag svg {
    width: 16px;
    height: 16px;
  }

  @media screen and (max-width: 600px) {
    .tag svg {
      width: 12px;
      height: 12px;
    }
  }
</style>

<style lang="scss">
  @use "@/styles/breakpoints" as *;

  :root {
    --span-tag-size: clamp(12px, 0.62rem + 0.42vw, 14px);
  }

  div {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    border-radius: 12px;
    background-color: var(--card-surface-input);

    &.highlight {
      border: 1px solid var(--accent-color);
    }

    &.outline {
      background-color: transparent;
      border: 1px solid var(--orange-border);
      color: var(--accent-color);
    }

    @include tablet {
      padding: 6px 12px;
    }

    @include mobile {
      padding: 4px 10px;
      gap: 5px;
    }
  }

  span {
    font-size: var(--span-tag-size);
    font-weight: 200;

    @include mobile {
      font-size: 0.75rem;
      font-weight: 500;
      line-height: 1.25rem;
    }
  }

  .tag {
    opacity: 0;

    &:not(.tag-animated) {
      background-color: var(--accent-tint);
      color: var(--accent-color);
    }

    &.show {
      opacity: 1;
    }
  }
</style>
