---
interface Props {
  title: string;
  icon?: string;
  animated?: boolean;
  highlight?: boolean;
  outline?: boolean;
  badge?: boolean;
  size?: "default" | "small";
}

const { animated, title, icon, highlight, outline, badge, size = "default" } = Astro.props;
const classes = [
  "tag",
  animated ? "tag-animated" : "show",
  highlight && "highlight",
  outline && "outline",
  badge && "badge",
  size === "small" && "small",
].filter(Boolean).join(" ");
---

<div class={classes}>
  {icon && <Fragment set:html={icon} />}
  <span>{title}</span>
</div>

<style lang="scss" is:global>
  .tag svg {
    width: 16px;
    height: 16px;
  }

  .tag.small svg {
    width: 12px;
    height: 12px;
  }

  @media screen and (max-width: 600px) {
    .tag svg {
      width: 12px;
      height: 12px;
    }
  }
</style>

<style lang="scss">
  @use "@/styles/breakpoints" as *;

  div {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    border-radius: 12px;
    background-color: var(--card-surface-input);

    &.small {
      padding: 2px 8px;
      border-radius: 6px;
      gap: 5px;

      span {
        font-size: 14px;
      }
    }

    &:not(.small) {
      @include tablet {
        padding: 6px 12px;
      }

      @include mobile {
        padding: 4px 10px;
        gap: 5px;
      }
    }

    &.highlight {
      border: 1px solid var(--accent-color);
    }

    &.outline {
      background-color: transparent;
      border: 1px solid var(--orange-border);
      color: var(--accent-color);
    }

    &.badge {
      background-color: var(--accent-color);
      color: var(--accent-cool-shift);

      span {
        font-weight: 400;
      }

      &::selection, *::selection {
        background-color: black;
        color: var(--accent-color);
      }
    }
  }

  span {
    font-size: clamp(12px, 0.62rem + 0.42vw, 14px);
    font-weight: 300;

    @include mobile {
      font-size: 0.75rem;
      font-weight: 500;
      line-height: 1.25rem;
    }
  }

  .tag {
    opacity: 0;

    &:not(.tag-animated):not(.badge) {
      background-color: var(--accent-tint);
      color: var(--accent-color);
    }

    &.show {
      opacity: 1;
    }
  }
</style>
