---
interface Props {
  color: string;
  class?: string;
  style?: string;
}

const { color, class: className, style } = Astro.props;
const inlineStyle = [`--spotlight-color: ${color}`, style].filter(Boolean).join("; ");
---

<div
  class:list={["spotlight-card", className]}
  data-spotlight-card
  data-animate-card
  style={inlineStyle}
>
  <div class="spotlight-inner">
    <slot />
  </div>
</div>

<style lang="scss">
  .spotlight-card {
    position: relative;
    overflow: hidden;
    border-radius: 32px;
    padding: 1px;
    background-color: rgba(71, 85, 105, 0.48);

    &::before,
    &::after {
      content: "";
      position: absolute;
      background: var(--spotlight-color);
      border-radius: 9999px;
      filter: blur(100px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 500ms;
      transform: translateX(var(--mouse-x, 0px)) translateY(var(--mouse-y, 0px));
      will-change: transform;
    }

    &::before {
      width: 20rem;
      height: 20rem;
      left: -10rem;
      top: -10rem;
      z-index: 2;
    }

    &::after {
      width: 24rem;
      height: 24rem;
      left: -12rem;
      top: -12rem;
      z-index: 4;
    }
  }

  :global([data-spotlight]):hover .spotlight-card {
    &::before {
      opacity: 1;
    }

    &::after {
      opacity: 0.1;
    }
  }

  @media (hover: none) {
    .spotlight-card {
      &::before,
      &::after {
        display: none;
      }
    }
  }

  .spotlight-inner {
    position: relative;
    z-index: 3;
    background-color: var(--card-surface);
    background: linear-gradient(45deg, #172033, #1e293b 50%, #172033);
    border-radius: 31px;
    height: 100%;
  }
</style>
