---
interface Props {
  id: string;
  triggerId: string;
  width?: string;
  class?: string;
}

const { id, triggerId, width = "280px", class: className } = Astro.props;
---

<div class="mobile-drawer-backdrop" id={`${id}-backdrop`}></div>

<aside
  class:list={["mobile-drawer-panel", className]}
  id={`${id}-panel`}
  data-drawer-trigger={triggerId}
  style={`--drawer-width: ${width};`}
  aria-label="Menu de navigation"
  aria-hidden="true"
>
  <slot />
</aside>

<script>
  function initDrawers() {
    document.querySelectorAll<HTMLElement>("[data-drawer-trigger]").forEach((panel) => {
      if (panel.dataset.drawerBound) return;
      panel.dataset.drawerBound = "true";

      const triggerId = panel.dataset.drawerTrigger;
      if (!triggerId) return;
      const id = panel.id.replace("-panel", "");
      const trigger = document.getElementById(triggerId);
      const backdrop = document.getElementById(`${id}-backdrop`);

      function toggle() {
        const isOpen = panel.classList.toggle("open");
        trigger?.classList.toggle("open", isOpen);
        backdrop?.classList.toggle("open", isOpen);
        document.body.style.overflow = isOpen ? "hidden" : "";
        panel.setAttribute("aria-hidden", String(!isOpen));
        trigger?.setAttribute("aria-expanded", String(!!isOpen));
      }

      function close() {
        panel.classList.remove("open");
        trigger?.classList.remove("open");
        backdrop?.classList.remove("open");
        document.body.style.overflow = "";
        panel.setAttribute("aria-hidden", "true");
        trigger?.setAttribute("aria-expanded", "false");
      }

      trigger?.addEventListener("click", toggle);
      backdrop?.addEventListener("click", close);

      panel.querySelectorAll("a, [data-close-drawer]").forEach((el) => {
        el.addEventListener("click", close);
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && panel.classList.contains("open")) {
          close();
        }
      });

      window.addEventListener("resize", () => {
        if (panel.classList.contains("open")) close();
      });
    });
  }

  document.addEventListener("astro:page-load", initDrawers);
  initDrawers();
</script>

<style lang="scss">
  .mobile-drawer-backdrop {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    z-index: 999;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;

    &.open {
      opacity: 1;
      pointer-events: auto;
    }
  }

  .mobile-drawer-panel {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: var(--drawer-width);
    max-width: 85vw;
    max-height: 100dvh;
    padding: 24px 16px 80px 16px;
    background-color: var(--background-color);
    border-left: 1px solid var(--border-color);
    z-index: 1000;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    overflow-y: auto;
    box-shadow: -8px 0 32px rgba(0, 0, 0, 0.3);
    display: flex;
    flex-direction: column;
    gap: 16px;

    &.open {
      transform: translateX(0);
    }
  }
</style>
