---
import IconButton from "@/components/shared/atoms/IconButton.astro";
import message from "@/svgs/message.svg?raw";
---

<IconButton
  id="floating-contact"
  href="#contact"
  label="Me contacter"
  size="small"
  class="floating-contact"
>
  <Fragment set:html={message} />
</IconButton>

<script>
  import { onScrollAndResize } from "@/lib/dom/onWindowEvent";
  import {
    createViewDetection,
    anchorsQueryToViewDetectionElement,
  } from "@/lib/dom/viewDetection";

  function hideContactWhenSectionVisible() {
    const targets = anchorsQueryToViewDetectionElement("#floating-contact", {
      onInside: (el) => el.classList.add("current"),
      onOutside: (el) => el.classList.remove("current"),
    });

    const checkVisibility = createViewDetection(targets, {
      setOffset: (height) => height,
      setBounds: (offset) => [offset, 0],
    });

    onScrollAndResize(checkVisibility);
  }

  window.addEventListener("load", hideContactWhenSectionVisible);
</script>

<style lang="scss" is:global>
  @use "@/styles/breakpoints" as *;

  .floating-contact.icon-button {
    display: none;
  }

  @include mobile {
    .floating-contact {
      &.icon-button {
        position: sticky;
        z-index: 300;
        bottom: 36px;
        right: 12px;
        margin-left: auto;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background-color: var(--card-surface);
        border: 1px solid var(--border-color);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        cursor: pointer;
        transition: all 0.3s ease;

        &:hover {
          background-color: var(--card-surface-hover);
          border-color: var(--border-hover-color);
        }
      }

      svg {
        width: 20px;
        height: 20px;

        path {
          fill: var(--accent-color);
        }
      }

      &.current {
        pointer-events: none;
        opacity: 0;
      }
    }
  }
</style>
