---
import ContactForm from "./ContactForm.tsx";
import RevealText from "@/components/shared/atoms/RevealText/RevealText.astro";
import ButtonLink from "@/components/shared/atoms/ButtonLink.astro";
import linkedin from "@/svgs/linkedin.svg?raw";
---

<section id="contact" data-animate-section>
  <RevealText text="Parlons de" as="span" class="subtitle" trigger="reveal:section:contact" />
  <RevealText text="Votre projet" as="h2" trigger="reveal:section:contact" />
  <div class="contact-content">
    <div class="contact-description">
      <p>
        Vous cherchez un développeur frontend freelance expérimenté pour lancer
        un produit, faire évoluer une application ou renforcer votre équipe ?
      </p>
      <br />
      <p>
        Décrivez votre contexte et vos objectifs. Je vous recontacte rapidement
        pour vous proposer des solutions claires, adaptées et pragmatiques.
      </p>
      <ButtonLink href="https://www.linkedin.com/in/martin-kinoo/" text="Me retrouver sur LinkedIn" icon={linkedin} />
    </div>
    <ContactForm
      client:load
      accessToken={import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY}
    />
  </div>
</section>

<style lang="scss">
  section {
    margin: var(--section-margin) 0;

    :global(.subtitle) {
      display: block;
      color: var(--accent-color);
      font-weight: 200;
      font-size: var(--subtitle-size);
      margin: 0;
    }

    :global(h2) {
      display: block;
      overflow: hidden;
      padding-bottom: 0.15em;
    }
  }

  .contact-description {
    p {
      font-size: var(--hero-font-size);
      font-weight: 200;
    }

    :global(.button-link) {
      margin-top: 24px;
    }
  }

  .contact-content {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(24px, 1.24rem + 1.13vw, 36px);
    align-items: start;
  }

  @media screen and (max-width: 1024px) {
    .contact-content {
      grid-template-columns: 1fr;
    }
  }
</style>
