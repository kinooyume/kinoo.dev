---
import type { DiagramCycleStep } from "./types";
import { colorStyle } from "./types";

interface Props {
  steps: DiagramCycleStep[];
}

const { steps } = Astro.props;
---

<div class="diagram-cycle">
  {steps.map((step, i) => (
    <>
      <div class="cycle-step" style={colorStyle(step.color)}>
        <span class="cycle-label">{step.label}</span>
      </div>
      <span class:list={["cycle-arrow", { "cycle-arrow-last": i === steps.length - 1 }]}>&rarr;</span>
    </>
  ))}
</div>

<style>
  .diagram-cycle {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    row-gap: 8px;
  }

  .cycle-step {
    background: var(--cell-bg);
    border: 1px solid var(--cell-border);
    color: var(--cell-text);
    padding: 10px 16px;
    border-radius: 8px;
    text-align: center;
  }

  .cycle-label {
    font-weight: 500;
  }

  .cycle-arrow {
    color: var(--accent-color);
    font-size: 1.2em;
    padding: 0 8px;
    flex-shrink: 0;
  }

  .cycle-arrow-last {
    transform: scaleX(-1) rotate(180deg);
  }
</style>
