---
import type { DiagramCycleStep } from "./types";
import { colorStyle } from "./types";
import DiagramArrowIcon from "./DiagramArrowIcon.astro";

interface Props {
  steps: DiagramCycleStep[];
}

const { steps } = Astro.props;
---

<div class="diagram-cycle">
  {steps.map((step, i) => (
    <>
      <div class="cycle-step" style={colorStyle(step.color)}>
        <span class="cycle-label">{step.label}</span>
      </div>
      <DiagramArrowIcon loop={i === steps.length - 1} />
    </>
  ))}
</div>

<style>
  .diagram-cycle {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    row-gap: 8px;
  }

  .cycle-step {
    background: var(--cell-bg);
    border: 1px solid var(--cell-border);
    color: var(--cell-text);
    padding: 10px 16px;
    border-radius: 8px;
    text-align: center;

    &::selection, & *::selection {
      background-color: var(--cell-text);
      color: var(--background-color);
    }
  }

  .cycle-label {
    font-weight: 500;
  }
</style>
