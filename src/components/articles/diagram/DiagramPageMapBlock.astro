---
import type { PageMapBlock } from "./types";
import { colorStyle, badgeStyle } from "./types";

interface Props {
  block: PageMapBlock;
}

const { block } = Astro.props;
const Self = Astro.self;
---

<div
  class:list={["block", { "has-children": !!block.children?.length }]}
  style={colorStyle(block.color)}
>
  <div class="block-header">
    <span class="block-label">{block.label}</span>
    {block.detail && <span class="block-detail">{block.detail}</span>}
    {block.badge && <span class="block-badge" style={badgeStyle(block.color)}>{block.badge}</span>}
  </div>
  {block.children && (
    <div class:list={["block-children", block.direction === "row" ? "row" : "col"]}>
      {block.children.map((child) => (
        <Self block={child} />
      ))}
    </div>
  )}
</div>

<style>
  .block {
    background: var(--cell-bg);
    border: 1px solid var(--cell-border);
    color: var(--cell-text);
    border-radius: 8px;
    padding: 10px 14px;
    flex: 1;
    min-width: 0;

    &::selection, & *::selection {
      background-color: var(--cell-text);
      color: var(--background-color);
    }
  }

  .block.has-children {
    padding-bottom: 12px;
  }

  .block-header {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .block-label {
    font-weight: 600;
    font-size: var(--font-size-sm);
  }

  .block-detail {
    color: var(--text-muted);
    font-size: var(--font-size-2xs);
  }

  .block-badge {
    background: var(--cell-bg);
    color: var(--cell-text);
    font-size: var(--font-size-2xs);
    font-weight: 600;
    padding: 1px 6px;
    border-radius: 4px;
    white-space: nowrap;
    margin-left: auto;

    &::selection {
      background-color: var(--cell-text);
      color: var(--cell-bg);
    }
  }

  .block-children {
    display: flex;
    gap: 4px;
    margin-top: 8px;
  }

  .block-children.row {
    flex-direction: row;
  }

  .block-children.col {
    flex-direction: column;
  }

  @media (max-width: 580px) {
    .block-children.row {
      flex-direction: column;
    }
  }
</style>
