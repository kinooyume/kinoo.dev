---
import Spotlight from "@/components/shared/molecules/Spotlight.astro";
import Card from "@/components/shared/molecules/Card/Card.astro";
import TagRow from "@/components/shared/atoms/TagRow.astro";
import Tag from "@/components/shared/atoms/Tag.astro";
import arrowRight from "@/svgs/arrow.svg?raw";

interface Props {
  title: string;
  subtitle?: string;
  date: Date;
  tags: string[];
  href: string;
}

const { title, subtitle, date, tags, href } = Astro.props;

const formattedDate = date.toLocaleDateString("fr-FR", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a href={href} class="article-card-link" aria-label={title}>
  <Spotlight color="var(--accent-color)">
    <Card>
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <h3>{title}<span class="arrow" aria-hidden="true" set:html={arrowRight} /></h3>
      {subtitle && <p>{subtitle}</p>}
      {tags.length > 0 && (
        <TagRow class="article-card-tags">
          {tags.map((tag) => <Tag title={tag} />)}
        </TagRow>
      )}
    </Card>
  </Spotlight>
</a>

<style lang="scss">
  .article-card-link {
    text-decoration: none;
    display: block;
  }

  time {
    font-size: 13px;
    color: var(--text-muted);
  }

  .article-card-tags {
    padding-top: 16px;
  }

  h3 {
    font-size: var(--h3-size);
    font-weight: 400;
    color: var(--secondary-accent-color);
    margin: 8px 0 12px;

    .arrow {
      display: inline-flex;
      align-items: center;
      margin-left: 8px;
      opacity: 0;
      transform: translateX(-4px) translateY(-0.1em);
      transition: all 0.2s ease;

      :global(svg) {
        width: 0.5em;
        height: 0.5em;
        fill: currentColor;
      }
    }
  }

  .article-card-link:hover h3 .arrow {
    opacity: 1;
    transform: translateX(0) translateY(-0.1em);
  }

  p {
    color: var(--text-muted);
    font-weight: 400;
    line-height: 1.6;
    margin-bottom: 0;
  }
</style>
