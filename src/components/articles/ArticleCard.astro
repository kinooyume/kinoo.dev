---
import Spotlight from "@/components/shared/molecules/Spotlight.astro";
import Card from "@/components/shared/molecules/Card/Card.astro";
import CardContent from "@/components/shared/molecules/Card/CardContent.astro";
import CardDescription from "@/components/shared/molecules/Card/CardDescription.astro";
import TagRow from "@/components/shared/atoms/TagRow.astro";
import Tag from "@/components/shared/atoms/Tag.astro";
import arrowRight from "@/svgs/arrow.svg?raw";

interface Props {
  title: string;
  subtitle?: string;
  date: Date;
  tags: string[];
  href: string;
}

const { title, subtitle, date, tags, href } = Astro.props;

const formattedDate = date.toLocaleDateString("fr-FR", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a href={href} class="article-card-link" aria-label={title}>
  <Spotlight color="var(--accent-color)">
    <Card>
      <CardContent>
        <div slot="title" class="article-title">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          <h3>{title}<span class="arrow" aria-hidden="true" set:html={arrowRight} /></h3>
        </div>
        {subtitle && (
          <CardDescription>
            <p>{subtitle}</p>
          </CardDescription>
        )}
        {tags.length > 0 && (
          <TagRow class="article-card-tags">
            {tags.map((tag) => <Tag title={tag} />)}
          </TagRow>
        )}
      </CardContent>
    </Card>
  </Spotlight>
</a>

<style lang="scss">
  .article-card-link {
    text-decoration: none;
    display: block;
  }

  time {
    font-size: 13px;
    color: var(--text-muted);
  }

  .article-card-tags {
    padding-top: 16px;
  }

  h3 {
    margin: 8px 0 0;

    .arrow {
      display: inline-flex;
      align-items: center;
      vertical-align: middle;
      margin-left: 8px;
      opacity: 0;
      transform: translateX(-4px) translateY(-0.1em);
      transition: all 0.2s ease;

      :global(svg) {
        width: 0.5em;
        height: 0.5em;
        fill: currentColor;
      }
    }
  }

  .article-card-link:hover h3 .arrow {
    opacity: 1;
    transform: translateX(0) translateY(-0.1em);
  }
</style>
