---
import type { DiagramRow, DiagramArrowData, DiagramFlowStep, DiagramTreeNode, DiagramCompareColumn, DiagramCycleStep, PageMapBlock } from "./diagram/types";
export type { DiagramColor, DiagramRow, DiagramNode, DiagramArrowData, DiagramArrowData as DiagramArrow, DiagramFlowStep, DiagramTreeNode, DiagramCompareColumn, DiagramCycleStep, PageMapBlock } from "./diagram/types";

import DiagramWrapper from "./diagram/Diagram.astro";
import DiagramStack from "./diagram/DiagramStack.astro";
import DiagramArrow from "./diagram/DiagramArrow.astro";
import DiagramFlow from "./diagram/DiagramFlow.astro";
import DiagramTree from "./diagram/DiagramTree.astro";
import DiagramCompare from "./diagram/DiagramCompare.astro";
import DiagramCycle from "./diagram/DiagramCycle.astro";
import DiagramPageMap from "./diagram/DiagramPageMap.astro";

interface Props {
  rows?: DiagramRow[];
  arrow?: DiagramArrowData;
  flow?: DiagramFlowStep[];
  tree?: DiagramTreeNode[];
  compare?: DiagramCompareColumn[];
  cycle?: DiagramCycleStep[];
  pagemap?: PageMapBlock[];
  caption?: string;
}

const { rows, arrow, flow, tree, compare, cycle, pagemap, caption } = Astro.props;
---

<DiagramWrapper caption={caption}>
  {rows && <DiagramStack rows={rows} />}
  {arrow && <DiagramArrow {...arrow} />}
  {flow && <DiagramFlow steps={flow} />}
  {tree && <DiagramTree nodes={tree} />}
  {compare && <DiagramCompare columns={compare} />}
  {cycle && <DiagramCycle steps={cycle} />}
  {pagemap && <DiagramPageMap blocks={pagemap} />}
</DiagramWrapper>
