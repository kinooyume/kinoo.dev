---
import sun from "@/svgs/sun.svg?raw";
import moon from "@/svgs/moon.svg?raw";
---

<button class="theme-toggle" aria-label="Changer de thème">
  <span class="theme-icon icon-sun" set:html={sun} />
  <span class="theme-icon icon-moon" set:html={moon} />
</button>

<script>
  import { animate } from "animejs";
  import { getTheme, toggleTheme } from "@/lib/theme";

  function animateToggle(btn: HTMLButtonElement) {
    const isDark = getTheme() === "dark";
    const outgoing = btn.querySelector<HTMLElement>(isDark ? ".icon-moon" : ".icon-sun");
    const incoming = btn.querySelector<HTMLElement>(isDark ? ".icon-sun" : ".icon-moon");
    if (!outgoing || !incoming) return;

    btn.style.pointerEvents = "none";

    animate(outgoing, {
      translateX: [0, 12],
      translateY: [0, 10],
      rotate: [0, 120],
      opacity: [1, 0],
      scale: [1, 0.6],
      duration: 250,
      ease: "inQuad",
      onComplete() {
        outgoing.style.display = "none";
        toggleTheme();

        incoming.style.display = "flex";
        animate(incoming, {
          translateX: [-12, 0],
          translateY: [10, 0],
          rotate: [-120, 0],
          opacity: [0, 1],
          scale: [0.6, 1],
          duration: 500,
          ease: "outElastic(1, 0.6)",
          onComplete() {
            btn.style.pointerEvents = "";
          },
        });
      },
    });
  }

  function initToggle() {
    document.querySelectorAll<HTMLButtonElement>(".theme-toggle").forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = "true";

      const isDark = getTheme() === "dark";
      const sun = btn.querySelector<HTMLElement>(".icon-sun");
      const moon = btn.querySelector<HTMLElement>(".icon-moon");
      if (sun) sun.style.display = isDark ? "none" : "flex";
      if (moon) moon.style.display = isDark ? "flex" : "none";

      btn.addEventListener("click", () => animateToggle(btn));
    });
  }

  document.addEventListener("astro:page-load", initToggle);
  initToggle();
</script>

<style lang="scss">
  .theme-toggle {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 22px;
    height: 22px;
    color: var(--color);
    opacity: var(--opacity-muted);
    transition: opacity var(--transition-base), color var(--transition-base);
    cursor: pointer;
    overflow: hidden;

    &:hover {
      opacity: 1;
      color: var(--accent-color);
    }
  }

  .theme-icon {
    display: flex;
    align-items: center;
    justify-content: center;

    :global(svg) {
      width: 20px;
      height: 20px;
    }
  }
</style>
