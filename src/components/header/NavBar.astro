---
export interface NavItem {
  label: string;
  href: string;
  color: string;
}

interface Props {
  items?: NavItem[];
}

const defaultItems: NavItem[] = [
  { label: "Articles", href: "/#articles", color: "var(--orange)" },
  { label: "Réalisations", href: "/#realisations", color: "var(--green)" },
  { label: "Expériences", href: "/#experiences", color: "var(--pink)" },
  { label: "Formations", href: "/#formations", color: "var(--purple)" },
];

const { items = defaultItems } = Astro.props;
---

<nav class="navbar">
  <ul>
    {
      items.map((item) => (
        <li>
          <a class="anime nav" href={item.href} data-color={item.color}>
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
  <div class="indicator"></div>
</nav>

<script>
  import { animate, type JSAnimation } from "animejs";
  import { onScrollAndResize } from "@/lib/dom/onWindowEvent";
  import {
    createViewDetection,
    anchorsQueryToViewDetectionElement,
  } from "@/lib/dom/viewDetection";
  import { onHeroAnimationComplete } from "@/lib/animations/onHeroAnimationComplete";

  function initNavbar() {
    const navbarEl = document.querySelector(".navbar");
    if (!navbarEl) return;
    const navbar = navbarEl as HTMLElement;
    const indicator = navbar.querySelector(".indicator") as HTMLElement;
    const ul = navbar.querySelector("ul") as HTMLElement;

    let isHovering = false;
    let activeLink: HTMLElement | null = null;
    let hoverTimeout: number | null = null;
    let currentAnim: JSAnimation | null = null;

    function moveIndicator(target: HTMLElement | null) {
      if (currentAnim) {
        currentAnim.pause();
        currentAnim = null;
      }

      if (!target) {
        currentAnim = animate(indicator, {
          opacity: 0,
          duration: 200,
          ease: "outQuad",
        });
        return;
      }

      const rect = target.getBoundingClientRect();
      const navRect = navbar.getBoundingClientRect();

      indicator.style.setProperty(
        "--indicator-color",
        target.dataset.color || "var(--orange)",
      );
      currentAnim = animate(indicator, {
        left: rect.left - navRect.left,
        width: rect.width,
        opacity: 1,
        duration: 300,
        ease: "outCubic",
      });
    }

    ul.querySelectorAll("a").forEach((link) => {
      link.addEventListener("mouseenter", () => {
        if (hoverTimeout) clearTimeout(hoverTimeout);
        isHovering = true;
        moveIndicator(link as HTMLElement);
      });
    });

    ul.addEventListener("mouseleave", () => {
      isHovering = false;
      hoverTimeout = window.setTimeout(() => {
        if (!isHovering) moveIndicator(activeLink);
      }, 150);
    });

    const navLinks = Array.from(navbar.querySelectorAll("a"));
    const targets = anchorsQueryToViewDetectionElement(".navbar a");

    const detect = createViewDetection(targets, {
      setBounds: (offset) => [offset, 0],
      onBestMatch: (best) => {
        navLinks.forEach((a) => a.classList.remove("current"));
        if (best) {
          const idx = targets.indexOf(best);
          navLinks[idx]?.classList.add("current");
        }
      },
    });

    function checkVisibility() {
      detect();
      const newActive = navbar.querySelector("a.current") as HTMLElement | null;
      if (newActive !== activeLink) {
        activeLink = newActive;
        if (!isHovering) moveIndicator(activeLink);
      }
    }

    function enable() {
      navbar.classList.add("enabled");
      onScrollAndResize(checkVisibility, "navbarDetection");
    }

    const hasHero = !!document.getElementById("hero");
    if (hasHero) {
      onHeroAnimationComplete(enable);
    } else {
      enable();
    }
  }

  window.addEventListener("load", initNavbar);
</script>

<style lang="scss">
  @use "@/styles/breakpoints" as *;

  .navbar {
    position: relative;
    pointer-events: none;
    margin-top: 12px;

    &.enabled {
      pointer-events: auto;
    }
  }

  ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0px 8px;
    margin: -8px;
    margin-bottom: 0;
  }

  li {
    margin-bottom: 0;
  }

  a {
    display: block;
    padding: 12px;
    font-size: 18px;
    font-weight: 200;
    color: var(--color);
    text-decoration: none;
    opacity: 0.6;
    transition:
      opacity 0.3s ease-in-out,
      transform 0.3s ease;

    &:hover,
    &.current {
      opacity: 1;
    }

    &[data-color="var(--pink)"] {
      &:hover,
      &.current {
        color: var(--pink-lightest);
      }
    }

    &[data-color="var(--green)"] {
      &:hover,
      &.current {
        color: var(--green-lightest);
      }
    }

    &[data-color="var(--purple)"] {
      &:hover,
      &.current {
        color: var(--purple-lightest);
      }
    }

    &[data-color="var(--orange)"] {
      &:hover,
      &.current {
        color: var(--orange-lightest);
      }
    }
  }

  .indicator {
    --indicator-color: var(--orange);
    position: absolute;
    bottom: 8px;
    height: 2px;
    background: var(--indicator-color);
    border-radius: 1px;
    opacity: 0;
    pointer-events: none;
    box-shadow: 0 0 6px
      color-mix(in srgb, var(--indicator-color) 50%, transparent);
  }

  @include wide {
    .navbar {
      display: none;
    }
  }
</style>
