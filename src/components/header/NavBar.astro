---
export interface NavItem {
  label: string;
  href: string;
  color: string;
}

interface Props {
  items?: NavItem[];
}

const defaultItems: NavItem[] = [
  { label: "Articles", href: "/#articles", color: "var(--orange-dark)" },
  { label: "Réalisations", href: "/#realisations", color: "var(--green-dark)" },
  { label: "Expériences", href: "/#experiences", color: "var(--pink-dark)" },
  { label: "Formations", href: "/#formations", color: "var(--purple-dark)" },
];

const { items = defaultItems } = Astro.props;
---

<nav class="navbar">
  <ul>
    {
      items.map((item) => (
        <li>
          <a class="anime nav" href={item.href} data-color={item.color}>
            {item.label}
          </a>
        </li>
      ))
    }
    <li class="push-right">
      <a class="anime nav" href="/design-system" data-color="var(--orange-dark)" data-page>
        Design System
      </a>
    </li>
  </ul>
  <div class="indicator"></div>
</nav>

<script>
  import { animate, type JSAnimation } from "animejs";
  import { onScrollAndResize } from "@/lib/dom/onWindowEvent";
  import {
    createViewDetection,
    anchorsQueryToViewDetectionElement,
  } from "@/lib/dom/viewDetection";
  import { onHeroAnimationComplete } from "@/lib/animations/onHeroAnimationComplete";

  function initNavbar() {
    const navbarEl = document.querySelector(".navbar");
    if (!navbarEl) return;
    const navbar = navbarEl as HTMLElement;
    const indicator = navbar.querySelector(".indicator") as HTMLElement;

    let isHovering = false;
    let activeLink: HTMLElement | null = null;
    let hoverTimeout: number | null = null;
    let currentAnim: JSAnimation | null = null;

    function moveIndicator(target: HTMLElement | null, instant = false) {
      if (currentAnim) {
        currentAnim.pause();
        currentAnim = null;
      }

      if (!target) {
        currentAnim = animate(indicator, {
          opacity: 0,
          duration: 200,
          ease: "outQuad",
        });
        return;
      }

      const rect = target.getBoundingClientRect();
      const navRect = navbar.getBoundingClientRect();

      indicator.style.setProperty(
        "--indicator-color",
        target.dataset.color || "var(--orange-dark)",
      );

      if (instant) {
        indicator.style.left = `${rect.left - navRect.left}px`;
        indicator.style.width = `${rect.width}px`;
        currentAnim = animate(indicator, {
          opacity: 1,
          duration: 500,
          ease: "outQuad",
        });
        return;
      }

      currentAnim = animate(indicator, {
        left: rect.left - navRect.left,
        width: rect.width,
        opacity: 1,
        duration: 300,
        ease: "outCubic",
      });
    }

    navbar.querySelectorAll("a").forEach((link) => {
      link.addEventListener("mouseenter", () => {
        if (hoverTimeout) clearTimeout(hoverTimeout);
        isHovering = true;
        moveIndicator(link as HTMLElement);
      });
    });

    navbar.addEventListener("mouseleave", () => {
      isHovering = false;
      hoverTimeout = window.setTimeout(() => {
        if (!isHovering) moveIndicator(activeLink);
      }, 150);
    });

    const pageLink = navbar.querySelector("a[data-page]") as HTMLElement | null;
    const pageLinkHref = pageLink?.getAttribute("href") ?? "";
    const isOnPageRoute = pageLink && pageLinkHref && window.location.pathname.startsWith(pageLinkHref);

    if (isOnPageRoute && pageLink) {
      pageLink.classList.add("current");
      activeLink = pageLink;
    }

    const scrollLinks = Array.from(navbar.querySelectorAll("a:not([data-page])"));
    const targets = anchorsQueryToViewDetectionElement(".navbar a:not([data-page])");

    const detect = createViewDetection(targets, {
      setBounds: (offset) => [offset, 0],
      onBestMatch: (best) => {
        scrollLinks.forEach((a) => a.classList.remove("current"));
        if (best) {
          const idx = targets.indexOf(best);
          scrollLinks[idx]?.classList.add("current");
          if (pageLink) pageLink.classList.remove("current");
        } else if (isOnPageRoute && pageLink) {
          pageLink.classList.add("current");
        }
      },
    });

    let firstCheck = true;

    function checkVisibility() {
      detect();
      const newActive = navbar.querySelector("a.current") as HTMLElement | null;
      if (newActive !== activeLink) {
        activeLink = newActive;
        if (!isHovering) moveIndicator(activeLink, firstCheck);
      }
      firstCheck = false;
    }

    if (isOnPageRoute) {
      moveIndicator(pageLink, true);
    }

    function enable() {
      navbar.classList.add("enabled");
      checkVisibility();
      onScrollAndResize(checkVisibility, "navbarDetection");
    }

    const hasHero = !!document.getElementById("hero");
    if (hasHero) {
      onHeroAnimationComplete(enable);
    } else {
      enable();
    }
  }

  document.addEventListener("astro:page-load", initNavbar);
  initNavbar();
</script>

<style lang="scss">
  @use "@/styles/breakpoints" as *;

  .navbar {
    position: relative;
    flex: 1;
    pointer-events: none;
    margin-top: 12px;

    &.enabled {
      pointer-events: auto;
    }
  }

  ul {
    list-style: none;
    display: flex;
    flex: 1;
    align-items: center;
    gap: 8px;
    padding: 0px 8px;
    margin: -8px;
    margin-bottom: 0;
  }

  li {
    margin-bottom: 0;

    &.push-right {
      margin-left: auto;
    }
  }

  a {
    display: block;
    padding: 12px;
    font-size: 18px;
    font-weight: 300;
    color: var(--color);
    text-decoration: none;
    opacity: 0.6;
    transition:
      opacity 0.3s ease-in-out,
      transform 0.3s ease;

    &:hover,
    &.current {
      opacity: 1;
    }

    &[data-color="var(--pink-dark)"] {
      &:hover,
      &.current {
        color: var(--pink-dark);
      }
    }

    &[data-color="var(--green-dark)"] {
      &:hover,
      &.current {
        color: var(--green-dark);
      }
    }

    &[data-color="var(--purple-dark)"] {
      &:hover,
      &.current {
        color: var(--purple-dark);
      }
    }

    &[data-color="var(--orange-dark)"] {
      &:hover,
      &.current {
        color: var(--orange-dark);
      }
    }
  }

  .indicator {
    --indicator-color: var(--orange-dark);
    position: absolute;
    bottom: 8px;
    height: 2px;
    background: var(--indicator-color);
    border-radius: 1px;
    opacity: 0;
    pointer-events: none;
    box-shadow: 0 0 6px
      color-mix(in srgb, var(--indicator-color) 50%, transparent);
  }

  @include wide {
    .navbar {
      display: none;
    }
  }
</style>
