---
import { accentColors } from "@/lib/colors";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["chromatic-preview", className]} data-chromatic>
  <div class="chromatic-toolbar">
    {accentColors.map((c) => (
      <button
        class:list={["chromatic-dot", { active: c.name === "Orange" }]}
        data-base={c.base}
        data-bright={c.bright}
        data-tint={c.tint}
        data-secondary={c.secondary}
        title={c.name}
        style={`--dot-color: var(${c.base})`}
      />
    ))}
  </div>
  <div class="chromatic-content" style="--accent-color: var(--orange); --accent-bright: var(--orange-dark); --accent-tint: var(--orange-tint); --secondary-accent-color: var(--orange-light);">
    <slot />
  </div>
</div>

<style lang="scss">
  .chromatic-preview {
    background-color: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    overflow: hidden;
  }

  .chromatic-toolbar {
    display: flex;
    gap: 6px;
    padding: 10px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .chromatic-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid transparent;
    background-color: var(--dot-color);
    cursor: pointer;
    padding: 0;
    transition: border-color 0.15s ease, transform 0.15s ease;

    &:hover {
      transform: scale(1.15);
    }

    &.active {
      border-color: var(--light-color);
    }
  }

  .chromatic-content {
    padding: 32px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;

    :global(.tag) {
      opacity: 1;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLDivElement>("[data-chromatic]").forEach((block) => {
    const content = block.querySelector<HTMLDivElement>(".chromatic-content");
    if (!content) return;
    const dots = block.querySelectorAll<HTMLButtonElement>(".chromatic-dot");

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        dots.forEach((d) => d.classList.remove("active"));
        dot.classList.add("active");
        content.style.setProperty("--accent-color", `var(${dot.dataset.base})`);
        content.style.setProperty("--accent-bright", `var(${dot.dataset.bright})`);
        content.style.setProperty("--accent-tint", `var(${dot.dataset.tint})`);
        content.style.setProperty("--secondary-accent-color", `var(${dot.dataset.secondary})`);
      });
    });
  });
</script>
