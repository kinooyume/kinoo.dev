---
import Sidebar from "@/components/sidebar/Sidebar.tsx";
import DSWipNotice from "./DSWipNotice.astro";
import { sidebarSections } from "./sections/index";

interface Props {
  title?: string;
  description?: string;
  currentSlug?: string;
}

const { title = "Design System", description, currentSlug } = Astro.props;
---

<div class="ds-container">
  <main class="ds-main">
    <h1>{title}</h1>
    <DSWipNotice>Work in progress. I'm adding components as I go, following patterns from what's already documented. Nothing here is set in stone yet.</DSWipNotice>
    {description && <p class="intro">{description}</p>}
    <slot name="intro" />

    <slot />

    <footer>
      <p>kinoo.dev · Design System</p>
    </footer>
  </main>

  <Sidebar sections={sidebarSections} currentSlug={currentSlug} showColorSwitcher class="ds-sidebar-desktop" client:load transition:persist="ds-sidebar" />
</div>

<script>
  import { restoreAccentColor, resetAccentColor } from "@/lib/colors";
  restoreAccentColor();
  document.addEventListener("astro:after-swap", () => {
    if (location.pathname.startsWith("/design-system")) {
      restoreAccentColor();
    } else {
      resetAccentColor();
    }
  });
</script>

<style lang="scss" is:global>
  @use "@/styles/breakpoints" as *;

  .ds-container {
    display: flex;
    min-height: calc(100vh - 80px);
    max-width: 1368px;
    margin: 0 auto;
    padding: 0 32px;
    gap: 48px;
    justify-content: space-between;
  }

  .ds-main {
    flex: 1;
    padding: 24px 0 64px 0;
    max-width: 900px;
    min-width: 0;
    overflow-x: auto;

    h1 {
      font-size: 48px;
      font-weight: 100;
      margin-bottom: 16px;
    }

    section {
      margin: 0 0 80px 0;
      padding-top: 24px;

      h2 {
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 16px;
        margin-bottom: 12px;
      }
    }

    footer {
      min-height: 50vh;
      display: flex;
      align-items: flex-end;
      padding-bottom: 32px;
      opacity: 0.5;

      p {
        font-size: 14px;
      }
    }
  }

  .intro {
    color: var(--color);
    margin-bottom: 16px;
    max-width: 600px;
  }

  .ds-intro {
    margin-bottom: 24px;
    max-width: 640px;

    > p {
      font-size: 16px;
      color: var(--color);
      margin-bottom: 16px;
    }
  }

  .ds-layer {
    padding: 12px 16px;
    border-left: 2px solid var(--border-color);
    margin-bottom: 12px;

    h3 {
      font-size: 15px;
      font-weight: 500;
      color: var(--light-color);
      margin-bottom: 4px;
    }

    p {
      font-size: 14px;
      color: var(--color);
      opacity: 0.8;
      line-height: 1.6;
    }

    code {
      font-size: 13px;
      background: var(--card-surface);
      padding: 1px 5px;
      border-radius: 3px;
    }
  }

  @include desktop {
    .ds-container {
      flex-direction: column;
      padding: 0 16px;
      gap: 0;
    }

    .ds-main {
      padding: 24px 0;
    }

    .ds-sidebar-desktop {
      display: none;
    }
  }
</style>
