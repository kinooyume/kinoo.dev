---
import Header from "@/components/header/Header.astro";
import Footer from "@/components/footer/Footer.astro";
import MobileDrawer from "@/components/shared/organisms/MobileDrawer.astro";
import MobileSidebar from "@/components/header/MobileSidebar.astro";
import { ClientRouter } from "astro:transitions";
import "@/styles/variables.scss";
import "@/styles/global.scss";
import "@/styles/animations.scss";

interface Props {
  title: string;
  description?: string;
  ogType?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
  title,
  description = "Développeur front-end freelance basé à Paris. Spécialisé en TypeScript, Svelte et Astro. Création de sites web performants et accessibles.",
  ogType = "website",
  ogImage = "https://kinoo.dev/og.jpg",
  jsonLd = {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    name: "Martin Kinoo",
    url: "https://kinoo.dev",
    description,
    image: "https://kinoo.dev/og.jpg",
    areaServed: {
      "@type": "City",
      name: "Paris",
    },
    knowsAbout: [
      "TypeScript",
      "React",
      "Svelte",
      "Astro",
      "SolidJS",
      "Front-end Development",
    ],
  },
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#181927" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Martin Kinoo" href="/rss.xml" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Martin Kinoo" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    <!-- Structured Data -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />

    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Aller au contenu</a>
    <Header>
      <slot name="header-nav" slot="nav" />
      <slot name="header-menu" />
    </Header>
    <div class="page-content">
      <slot />
      <Footer />
    </div>

    <div class="mobile-menu-drawer">
      <MobileDrawer id="mobile-menu" triggerId="mobile-menu-trigger">
        <slot name="mobile-sidebar">
          <MobileSidebar />
        </slot>
      </MobileDrawer>
    </div>
  </body>
</html>

<script>
  import { initFetchPrefetch } from "@/lib/dom/fetchPrefetch";
  initFetchPrefetch();
</script>

<script>
  import { animate } from "animejs";
  import { hasPlayed } from "@/lib/animations/sessionTracker";
  import { reset as resetEmitter } from "@/lib/emitter";
  import type { TransitionBeforeSwapEvent, TransitionBeforePreparationEvent } from "astro:transitions/client";

  function isDsPage() {
    return location.pathname.startsWith("/design-system");
  }

  function exitAnimation(): Promise<void> {
    const target = document.querySelector<HTMLElement>(isDsPage() ? ".ds-main" : ".page-content");
    if (!target) return Promise.resolve();
    return animate(target, {
      opacity: [1, 0],
      duration: 150,
      ease: "inQuad",
    }).then(() => {});
  }

  document.addEventListener("astro:before-preparation", (e) => {
    const ev = e as TransitionBeforePreparationEvent;
    const originalLoader = ev.loader;
    ev.loader = async () => {
      await Promise.all([exitAnimation(), originalLoader()]);
    };
  });

  document.addEventListener("astro:before-swap", (e) => {
    resetEmitter();
    document.body.style.overflow = "";
    const ev = e as TransitionBeforeSwapEvent;
    if (hasPlayed("hero") || hasPlayed("header")) {
      ev.newDocument.body.dataset.animationsDone = "";
    }
    ev.newDocument.documentElement.style.scrollBehavior = "auto";
  });

  // iOS Safari: orientation change can trigger a ghost popstate, leaving
  // the exit-animation opacity stuck at 0. Restore after resize settles.
  let resizeRAF: number;
  window.addEventListener("resize", () => {
    cancelAnimationFrame(resizeRAF);
    resizeRAF = requestAnimationFrame(() => {
      const sel = isDsPage() ? ".ds-main" : ".page-content";
      const el = document.querySelector<HTMLElement>(sel);
      if (el && el.style.opacity === "0") {
        el.style.opacity = "1";
      }
    });
  });

  document.addEventListener("astro:after-swap", () => {
    if (location.hash) {
      const target = document.querySelector<HTMLElement>(location.hash);
      if (target) {
        const headerHeight = parseInt(getComputedStyle(document.documentElement).getPropertyValue("--header-height")) || 120;
        window.scrollTo(0, target.offsetTop - headerHeight - 6);
      }
    }

    const target = document.querySelector<HTMLElement>(isDsPage() ? ".ds-main" : ".page-content");
    if (target) {
      animate(target, {
        opacity: [0, 1],
        duration: 200,
        ease: "outCubic",
      });
    }

    requestAnimationFrame(() => {
      document.documentElement.style.scrollBehavior = "";
    });
  });
</script>

<style lang="scss" is:global>
  @use "@/styles/breakpoints" as *;

  .skip-link {
    position: absolute;
    top: -100%;
    left: 16px;
    z-index: 10000;
    padding: 8px 16px;
    background: var(--accent-color);
    color: var(--background-color);
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;

    &:focus {
      top: 16px;
    }
  }

  .mobile-menu-drawer {
    display: none;

    @include desktop {
      display: block;
    }
  }

  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none;
  }

  ::view-transition-group(root) {
    animation-duration: 0s;
  }


  .page-content {
    padding-top: var(--header-height, 120px);
  }

</style>
