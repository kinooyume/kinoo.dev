---
import Layout from "./Layout.astro";
import TagRow from "@/components/shared/atoms/TagRow.astro";
import Tag from "@/components/shared/atoms/Tag.astro";
import ArrowLink from "@/components/shared/atoms/ArrowLink.astro";
import Prose from "@/components/articles/Prose.astro";
import BadgeLink from "@/components/shared/atoms/BadgeLink.astro";
import { type AccentTokens, categoryColors, defaultAccent } from "@/lib/categoryColors";

interface Props {
  title: string;
  subtitle?: string;
  description: string;
  date: Date;
  category?: string;
  tags: string[];
  links?: { text: string; href: string }[];
  ogImage?: string;
}

const { title, subtitle, description, date, category, tags, links = [], ogImage } = Astro.props;
const accent: AccentTokens = (category && categoryColors[category]) || defaultAccent;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const formattedDate = date.toLocaleDateString("fr-FR", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const blogPostingJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: date.toISOString(),
  author: {
    "@type": "Person",
    name: "Martin Kinoo",
    url: "https://kinoo.dev",
  },
  url: canonicalURL.href,
};
---

<Layout title={`${title} · Martin Kinoo`} description={description} ogType="article" ogImage={ogImage} jsonLd={blogPostingJsonLd}>

  <Fragment slot="head">
    <meta property="article:published_time" content={date.toISOString()} />
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
  </Fragment>

  <main>
    <article style={`--accent-color: ${accent.color}; --accent-tint: ${accent.tint}; --accent-bright: ${accent.bright}; --accent-bg: ${accent.bg}; --accent-cool-shift: ${accent.coolShift};`}>
      <header class="article-header">
        <ArrowLink href="/#articles" text="Portfolio" direction="back" />
        <h1>{title}</h1>
        {subtitle && <p class="subtitle">{subtitle}</p>}
        <div class="article-meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          {links.length > 0 && (
            <div class="article-links">
              {links.map((link) => (
                <BadgeLink href={link.href} text={link.text} />
              ))}
            </div>
          )}
        </div>
        {tags.length > 0 && (
          <TagRow class="article-tags">
            {tags.map((tag) => <Tag title={tag} />)}
          </TagRow>
        )}
      </header>
      <Prose>
        <slot />
      </Prose>
    </article>
  </main>
</Layout>

<style lang="scss">
  @use "@/styles/breakpoints" as *;

  main {
    margin: auto;
    padding: 1rem 32px;
    max-width: 1368px;

    @include tablet {
      padding: 1rem 16px;
    }
  }

  article {
    max-width: 960px;
    margin: 0 auto;
    padding-top: 48px;
    padding-bottom: 64px;
  }

  .article-header {
    margin-bottom: 48px;

    :global(.link) {
      margin-bottom: 24px;
      text-decoration: none;
    }
  }

  h1 {
    font-size: var(--h2-size);
    font-weight: 100;
    line-height: 1;
    color: var(--light-color);
    margin-bottom: 12px;
    text-wrap: balance;
  }

  .subtitle {
    font-size: 1.125rem;
    color: var(--text-muted);
    font-weight: 400;
    line-height: 1.5;
    margin-bottom: 12px;
    text-wrap: balance;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  time {
    font-size: var(--font-size-sm);
    font-weight: 200;
    color: var(--accent-color);

    :global(html[data-theme="light"]) & {
      color: var(--accent-bright);
    }
  }

  .article-tags {
    margin-top: 16px;
    padding-top: 0;
  }

  .article-links {
    display: flex;
    gap: 8px;
  }
</style>
